@import url('https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@400;600&family=Source+Sans+3:wght@300;400;500;600&display=swap');

* { margin: 0; padding: 0; box-sizing: border-box; }

/* ─── LIGHT THEME VARIABLES ─── */
:root {
  --blue: #1a3a6b;
  --blue-mid: #234d8f;
  --blue-light: #e8eef7;
  --red: #b5261e;
  --white: #ffffff;
  --off: #f5f6f8;
  --border: #d6dce8;
  --text: #1c1c1e;
  --muted: #5a6478;
  --light-text: #8892a4;
  --card-bg: #ffffff;
  --header-bg: #ffffff;
  --input-bg: #ffffff;
  --input-border: #d6dce8;
  --dropdown-bg: #ffffff;
  --sidebar-bg: #ffffff;
  --section-text: #1c1c1e;
  --strong-text: #1c1c1e;
  --blockquote-text: #1c1c1e;
  --tag-text: #1c1c1e;
  --nav-text: rgba(255,255,255,0.88);
}

/* ─── DARK THEME VARIABLES ─── */
[data-theme="dark"] {
  --white: #0f1117;
  --off: #161b27;
  --border: #2a3050;
  --text: #e2e8f0;
  --muted: #94a3b8;
  --light-text: #64748b;
  --card-bg: #1e2538;
  --blue-light: #1a2540;
  --header-bg: #0a0e1a;
  --input-bg: #1e2538;
  --input-border: #2a3050;
  --dropdown-bg: #1e2538;
  --sidebar-bg: #1e2538;
  --section-text: #e2e8f0;
  --strong-text: #f0f4f8;
  --blockquote-text: #cbd5e1;
  --tag-text: #e2e8f0;
  --nav-text: rgba(255,255,255,0.92);
}

/* ─── BASE ─── */
html { scroll-behavior: smooth; }

body {
  font-family: 'Source Sans 3', sans-serif;
  background: var(--white);
  color: var(--text);
  font-size: 14px;
  line-height: 1.6;
  transition: background 0.3s ease, color 0.3s ease;
}

a { text-decoration: none; color: inherit; }

/* ─── ANIMATIONS ─── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes slideLeft {
  from { opacity: 0; transform: translateX(-28px); }
  to   { opacity: 1; transform: translateX(0); }
}
@keyframes slideRight {
  from { opacity: 0; transform: translateX(28px); }
  to   { opacity: 1; transform: translateX(0); }
}
@keyframes marqueeLeft {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
@keyframes marqueeRight {
  from { transform: translateX(-50%); }
  to   { transform: translateX(0); }
}
@keyframes blink { 0%,100%{opacity:1}50%{opacity:0} }
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.94); }
  to   { opacity: 1; transform: scale(1); }
}

.animate-fade-up   { animation: fadeUp   0.6s ease both; }
.animate-fade-in   { animation: fadeIn   0.6s ease both; }
.animate-slide-left  { animation: slideLeft  0.6s ease both; }
.animate-slide-right { animation: slideRight 0.6s ease both; }
.animate-scale-in  { animation: scaleIn  0.5s ease both; }

.anim-delay-1 { animation-delay: 0.1s; }
.anim-delay-2 { animation-delay: 0.2s; }
.anim-delay-3 { animation-delay: 0.3s; }
.anim-delay-4 { animation-delay: 0.4s; }
.anim-delay-5 { animation-delay: 0.5s; }

/* ─── UTILBAR ─── */
.utilbar {
  background: var(--blue);
  padding: 6px 32px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.utilbar-left { color: rgba(255,255,255,0.55); font-size: 11px; }
.utilbar-right { display: flex; align-items: center; gap: 0; }
.utilbar-link {
  color: rgba(255,255,255,0.72);
  font-size: 11px;
  text-decoration: none;
  margin-left: 20px;
  letter-spacing: 0.2px;
  white-space: nowrap;
}
.utilbar-divider {
  width: 1px; height: 16px;
  background: rgba(255,255,255,0.2);
  margin: 0 14px;
  display: inline-block;
  flex-shrink: 0;
}
.theme-toggle {
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  color: white;
  width: 28px; height: 28px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  border-radius: 2px;
  margin-right: 10px;
  flex-shrink: 0;
}
.login-btn {
  display: flex; align-items: center; gap: 6px;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.25);
  color: white !important;
  font-size: 11px; font-weight: 600;
  padding: 4px 12px;
  letter-spacing: 0.3px;
  text-decoration: none;
  white-space: nowrap;
}

/* ─── HEADER ─── */
.site-header {
  background: var(--header-bg);
  border-bottom: 3px solid var(--blue);
  padding: 16px 32px;
  display: flex;
  align-items: center;
  gap: 20px;
}
.header-logo { width: 72px; height: 72px; flex-shrink: 0; }
.header-logo img { width: 100%; height: 100%; object-fit: contain; }
.header-divider { width: 1px; height: 56px; background: var(--border); flex-shrink: 0; }
.header-name {
  font-family: 'Source Serif 4, serif';
  font-size: 22px; font-weight: 600;
  color: var(--blue);
  line-height: 1.2; letter-spacing: -0.3px;
}
.header-sub { font-size: 12px; color: var(--muted); margin-top: 3px; }
.header-odia { font-size: 12px; color: var(--blue); font-weight: 500; margin-top: 2px; }
.header-right { margin-left: auto; display: flex; flex-direction: column; align-items: flex-end; gap: 10px; }
.header-badges { display: flex; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }
.header-badge {
  border: 1px solid var(--border);
  border-radius: 2px;
  padding: 4px 10px;
  font-size: 10px; font-weight: 600;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  color: var(--blue);
  background: transparent;
  white-space: nowrap;
}
.header-badge-filled { background: var(--blue); color: white; border-color: var(--blue); }
.search-form { display: flex; align-items: center; }
.search-input {
  background: var(--input-bg);
  border: 1px solid var(--input-border);
  color: var(--text);
  font-size: 11px;
  padding: 6px 12px;
  width: 260px;
  outline: none;
  transition: border-color 0.2s;
  font-family: inherit;
}
.search-input:focus { border-color: var(--blue); }
.search-btn {
  background: var(--blue);
  border: none;
  padding: 7px 12px;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
}

/* ─── NAV ─── */
.main-nav {
  background: var(--blue-mid);
  display: flex;
  align-items: stretch;
  position: relative;
  z-index: 500;
}
.nav-desktop { display: flex; align-items: stretch; flex: 1; overflow-x: visible; }
.nav-item-wrap { position: relative; }
.nav-link {
  color: var(--nav-text);
  font-size: 12.5px;
  font-weight: 400;
  text-decoration: none;
  padding: 11px 14px;
  border-right: 1px solid rgba(255,255,255,0.08);
  letter-spacing: 0.1px;
  white-space: nowrap;
  display: flex; align-items: center; gap: 4px;
  height: 100%;
  transition: background 0.15s;
}
.nav-link:hover { background: rgba(255,255,255,0.1); }
.nav-link-active { background: var(--red) !important; font-weight: 600; color: white !important; }
.nav-ext-links { margin-left: auto; display: flex; flex-shrink: 0; }
.nav-ext-link {
  color: rgba(255,255,255,0.88);
  font-size: 12.5px;
  padding: 11px 15px;
  border-left: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.08);
  white-space: nowrap;
}

/* ─── DROPDOWN ─── */
.nav-dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  background: var(--dropdown-bg);
  border: 1px solid var(--border);
  border-top: 2px solid var(--blue);
  min-width: 240px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.18);
  z-index: 600;
  opacity: 0;
  visibility: hidden;
  transform: translateY(-6px);
  transition: opacity 0.22s ease, visibility 0.22s, transform 0.22s ease;
  /* Invisible top padding bridges the gap between nav link and dropdown panel,
     preventing the hover from breaking as the mouse travels downward */
  padding-top: 6px;
  margin-top: -6px;
}
.nav-item-wrap:hover .nav-dropdown {
  opacity: 1;
  transform: translateY(0);
  visibility: visible;
}
.nav-dropdown-link {
  display: block;
  padding: 10px 16px;
  font-size: 12px;
  color: var(--text) !important;
  border-bottom: 1px solid var(--border);
  transition: background 0.15s, color 0.15s;
  white-space: nowrap;
}
.nav-dropdown-link:last-child { border-bottom: none; }
.nav-dropdown-link:hover { background: var(--blue-light); color: var(--blue) !important; }

/* ─── HAMBURGER ─── */
.hamburger {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  padding: 12px 16px;
  color: white;
  flex-direction: column;
  gap: 5px;
  align-items: center;
  justify-content: center;
}
.hamburger span {
  display: block;
  width: 22px; height: 2px;
  background: white;
  transition: all 0.3s;
}

/* ─── MOBILE DRAWER ─── */
.nav-drawer {
  position: fixed;
  top: 0; left: 0;
  width: 85%; max-width: 320px;
  height: 100vh;
  background: var(--blue);
  z-index: 1000;
  overflow-y: auto;
  transform: translateX(-100%);
  transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
  display: flex;
  flex-direction: column;
}
.nav-drawer.open { transform: translateX(0); }
.nav-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.55);
  z-index: 999;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
}
.nav-overlay.open { opacity: 1; visibility: visible; }
.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  flex-shrink: 0;
}
.drawer-logo { display: flex; align-items: center; gap: 10px; }
.drawer-logo img { width: 40px; height: 40px; object-fit: contain; }
.drawer-logo-text { font-family: 'Source Serif 4, serif'; font-size: 12px; color: white; line-height: 1.3; }
.drawer-close {
  background: rgba(255,255,255,0.1);
  border: none;
  color: white;
  width: 32px; height: 32px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  border-radius: 2px;
  font-size: 18px;
  flex-shrink: 0;
}
.drawer-nav { flex: 1; overflow-y: auto; }
.drawer-item { border-bottom: 1px solid rgba(255,255,255,0.06); }
.drawer-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px;
  color: rgba(255,255,255,0.9) !important;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  background: none;
  border: none;
  width: 100%;
  text-align: left;
  text-decoration: none;
}
.drawer-link:hover { background: rgba(255,255,255,0.06); }
.drawer-link-active { color: white !important; background: var(--red) !important; }
.drawer-chevron {
  transition: transform 0.2s;
  flex-shrink: 0;
}
.drawer-chevron.open { transform: rotate(180deg); }
.drawer-sub {
  overflow: hidden;
  max-height: 0;
  transition: max-height 0.3s ease;
  background: rgba(0,0,0,0.2);
}
.drawer-sub.open { max-height: 400px; }
.drawer-sub-link {
  display: block;
  padding: 10px 20px 10px 36px;
  color: rgba(255,255,255,0.7) !important;
  font-size: 12px;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  text-decoration: none;
}
.drawer-sub-link:hover { color: white !important; background: rgba(255,255,255,0.05); }
.drawer-footer {
  padding: 16px 20px;
  border-top: 1px solid rgba(255,255,255,0.1);
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}
.drawer-ext-btn {
  flex: 1;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  color: white;
  font-size: 12px;
  font-weight: 600;
  padding: 8px;
  text-align: center;
  text-decoration: none;
}

/* ─── HERO ─── */
.hero { background: var(--blue); position: relative; height: 340px; overflow: hidden; display: flex; }
.hero-bg { position: absolute; inset: 0; background: var(--blue); }
.hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to right, rgba(26,58,107,0.97) 38%, rgba(26,58,107,0.55) 70%, transparent 100%);
}
.hero-content {
  position: absolute; left: 0; top: 0; bottom: 0;
  width: 55%;
  padding: 36px 40px;
  display: flex; flex-direction: column; justify-content: center;
  z-index: 2;
}
.hero-tag {
  display: inline-block;
  background: var(--red);
  color: white;
  font-size: 10px; font-weight: 600;
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 4px 10px;
  margin-bottom: 14px;
  width: fit-content;
}
.hero-title {
  font-family: 'Source Serif 4, serif';
  font-size: 30px; font-weight: 600;
  color: white;
  line-height: 1.25;
  margin-bottom: 10px;
  white-space: pre-line;
}
.hero-desc {
  font-size: 13px;
  color: rgba(255,255,255,0.72);
  line-height: 1.7;
  max-width: 400px;
  margin-bottom: 22px;
}
.hero-btns { display: flex; gap: 10px; flex-wrap: wrap; }
.hero-btn-primary {
  background: white; color: var(--blue);
  font-size: 12px; font-weight: 600;
  padding: 10px 22px;
}
.hero-btn-secondary {
  background: transparent; color: white;
  font-size: 12px;
  padding: 10px 22px;
  border: 1px solid rgba(255,255,255,0.4);
}
.hero-dots {
  position: absolute; bottom: 16px; left: 40px;
  display: flex; gap: 6px; z-index: 3;
}
.hero-dot {
  width: 20px; height: 3px;
  background: rgba(255,255,255,0.3);
  border: none; cursor: pointer; padding: 0;
  transition: background 0.2s;
}
.hero-dot.active { background: white; }

/* ─── STATS ─── */
.stats-strip {
  background: var(--off);
  border-bottom: 1px solid var(--border);
  display: grid;
  grid-template-columns: repeat(5, 1fr);
}
.stat-item {
  padding: 16px 20px;
  border-right: 1px solid var(--border);
  text-align: center;
}
.stat-item:last-child { border-right: none; }
.stat-num {
  font-family: 'Source Serif 4, serif';
  font-size: 22px; font-weight: 600;
  color: var(--blue);
}
.stat-label { font-size: 11px; color: var(--muted); margin-top: 1px; }

/* ─── SECTION HEADING ─── */
.section-heading {
  display: flex; align-items: center; margin-bottom: 24px;
}
/* .section-heading h2 — see refinement rules below */
.section-heading-line {
  flex: 1; height: 2px;
  background: var(--border);
  align-self: flex-end;
}

/* ─── PAGE BANNER ─── */
.page-banner {
  background: var(--blue);
  padding: 28px 32px;
  border-bottom: 3px solid var(--red);
}
.page-banner-crumb {
  font-size: 11px;
  color: rgba(255,255,255,0.45);
  letter-spacing: 1.5px;
  text-transform: uppercase;
  margin-bottom: 4px;
}
.page-banner h1 {
  font-family: 'Source Serif 4, serif';
  font-size: 24px; font-weight: 600;
  color: white;
}

/* ─── HOME LAYOUT ─── */
.home-main {
  display: grid;
  grid-template-columns: 1fr 300px;
  border-bottom: 1px solid var(--border);
}
.home-content { padding: 32px; border-right: 1px solid var(--border); }
.home-sidebar { background: var(--sidebar-bg); }

/* ─── DEPARTMENTS ─── */
.dept-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--border);
}
.dept-card {
  background: var(--white);
  padding: 18px 16px;
  position: relative;
  border-top: 3px solid transparent;
  display: block;
  text-decoration: none;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.dept-card:hover { border-top-color: var(--blue); box-shadow: 0 4px 16px rgba(26,58,107,0.12); }
.dept-code {
  font-size: 13px; font-weight: 600;
  color: var(--blue);
  border: 2px solid var(--border);
  width: 44px; height: 44px;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 8px;
  transition: background 0.2s, color 0.2s;
}
.dept-card:hover .dept-code { background: var(--blue); color: white; border-color: var(--blue); }
.dept-name { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 4px; line-height: 1.3; }
.dept-since { font-size: 11px; color: var(--light-text); }
.dept-arrow { position: absolute; bottom: 16px; right: 14px; color: var(--light-text); font-size: 14px; }
.dept-count {
  background: var(--blue);
  padding: 18px 16px;
  display: flex; flex-direction: column;
  justify-content: center; align-items: center; text-align: center;
}

/* ─── TESTIMONIALS ─── */
.testimonial-section { padding: 48px 32px; background: var(--off); }
.testimonial-slider { position: relative; overflow: hidden; }
.testimonial-track {
  display: flex;
  transition: transform 0.5s cubic-bezier(0.4,0,0.2,1);
}
.testimonial-card {
  min-width: 100%;
  padding: 36px 40px;
  background: var(--white);
  border: 1px solid var(--border);
  position: relative;
}
.testimonial-quote-mark {
  font-family: Georgia, serif;
  font-size: 80px;
  color: var(--blue);
  opacity: 0.08;
  line-height: 1;
  position: absolute;
  top: 16px; left: 24px;
  user-select: none;
}
.testimonial-text {
  font-size: 14px;
  color: var(--muted);
  line-height: 1.9;
  font-style: italic;
  margin-bottom: 24px;
  position: relative;
  z-index: 1;
}
.testimonial-author { border-top: 1px solid var(--border); padding-top: 16px; display: flex; align-items: center; gap: 14px; }
.testimonial-avatar {
  width: 48px; height: 48px;
  background: var(--blue-light);
  border: 2px solid var(--border);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  font-family: 'Source Serif 4, serif';
  font-size: 16px; font-weight: 600;
  color: var(--blue);
}
.testimonial-name { font-size: 14px; font-weight: 600; color: var(--text); }
.testimonial-role { font-size: 11px; color: var(--muted); margin-top: 1px; }
.testimonial-company { font-size: 11px; color: var(--blue); font-weight: 600; margin-top: 2px; }
.testimonial-dots { display: flex; justify-content: center; gap: 8px; margin-top: 20px; }
.testimonial-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--border);
  border: none; cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}
.testimonial-dot.active { background: var(--blue); transform: scale(1.3); }
.testimonial-nav {
  position: absolute;
  top: 50%; transform: translateY(-50%);
  background: var(--blue);
  border: none;
  color: white;
  width: 36px; height: 36px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  z-index: 2;
  transition: background 0.2s;
}
.testimonial-nav:hover { background: var(--blue-mid); }
.testimonial-nav-prev { left: 8px; }
.testimonial-nav-next { right: 8px; }

/* ─── RECRUITERS MARQUEE ─── */
.recruiters-section { background: #0a1628; padding: 40px 0; overflow: hidden; border-top: 3px solid var(--red); }
.recruiters-header { padding: 0 32px 24px; display: flex; justify-content: space-between; align-items: baseline; }
.recruiters-marquee-wrap { overflow: hidden; }
.recruiters-row { display: flex; gap: 0; margin-bottom: 2px; }
.recruiters-row-inner {
  display: flex;
  gap: 2px;
  animation: marqueeLeft 25s linear infinite;
  white-space: nowrap;
}
.recruiters-row-inner.reverse {
  animation: marqueeRight 28s linear infinite;
}
.recruiters-row:hover .recruiters-row-inner { animation-play-state: paused; }
.recruiter-tag {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.14);
  padding: 10px 22px;
  font-size: 12px; font-weight: 600;
  color: rgba(255,255,255,0.9);
  letter-spacing: 0.3px;
  white-space: nowrap;
  flex-shrink: 0;
  transition: background 0.2s;
}
.recruiter-tag:hover { background: rgba(255,255,255,0.12); }

/* ─── NOTICE BOARD ─── */
.notice-item { display: flex; gap: 12px; padding: 11px 0; border-bottom: 1px dashed var(--border); align-items: flex-start; }
.notice-item:last-child { border-bottom: none; }
.notice-date { background: var(--blue); color: white; padding: 5px 8px; text-align: center; flex-shrink: 0; min-width: 42px; }
.notice-day { font-family: 'Source Serif 4, serif'; font-size: 17px; font-weight: 600; line-height: 1; }
.notice-mon { font-size: 9px; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.8; margin-top: 2px; }
.notice-title { font-size: 12.5px; color: var(--text); line-height: 1.5; }
.notice-title a { color: var(--text); }
.notice-title a:hover { color: var(--blue); }
.notice-cat { font-size: 11px; color: var(--light-text); }

/* ─── FOOTER ─── */
.site-footer { background: #112244; color: rgba(255,255,255,0.7); border-top: 1px solid rgba(255,255,255,0.08); }
.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 32px;
  padding: 40px 32px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.footer-col-title {
  font-size: 11px; font-weight: 600;
  color: white;
  letter-spacing: 1.2px; text-transform: uppercase;
  margin-bottom: 14px;
  padding-bottom: 8px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
.footer-link {
  display: block;
  color: rgba(255,255,255,0.55) !important;
  font-size: 12px;
  margin-bottom: 7px;
  transition: color 0.15s;
}
.footer-link:hover { color: rgba(255,255,255,0.9) !important; }

/* ─── FOOTER MAP ─── */
.footer-map-row {
  padding: 0 32px 32px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.footer-map-label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  font-weight: 600;
  color: rgba(255,255,255,0.5);
  letter-spacing: 0.8px;
  text-transform: uppercase;
  margin-bottom: 12px;
}
.footer-map-directions {
  margin-left: auto;
  font-size: 11px;
  color: rgba(255,255,255,0.4);
  text-decoration: none;
  font-weight: 500;
  letter-spacing: 0;
  text-transform: none;
  transition: color 0.15s;
}
.footer-map-directions:hover { color: white; }
.footer-map-embed:hover { filter: grayscale(0%) brightness(1); }

.footer-bottom {
  padding: 14px 32px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 11px;
  color: rgba(255,255,255,0.3);
  flex-wrap: wrap;
  gap: 8px;
}
.footer-bottom-links { display: flex; gap: 16px; }
.footer-bottom-link { color: rgba(255,255,255,0.35) !important; }

/* ─── SOCIAL SIDEBAR ─── */
.social-sidebar {
  position: fixed;
  right: 0; top: 50%;
  transform: translateY(-50%);
  z-index: 900;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.social-btn {
  width: 40px; height: 40px;
  display: flex; align-items: center; gap: 10px;
  padding: 0 11px;
  background: #ffffff;
  border-radius: 4px 0 0 4px;
  box-shadow: -2px 2px 12px rgba(0,0,0,0.35);
  text-decoration: none;
  overflow: hidden;
  transition: width 0.3s ease, background 0.3s ease;
  white-space: nowrap;
}
.social-btn svg { fill: var(--blue); transition: fill 0.3s ease; }
.social-btn:hover svg { fill: white; }
.social-btn:hover { width: 130px; }
.social-btn-label {
  color: white; font-size: 11px; font-weight: 600;
  opacity: 0;
  transition: opacity 0.2s;
  white-space: nowrap;
}
.social-btn:hover .social-btn-label { opacity: 1; }

/* ─── BACK TO TOP ─── */
.back-to-top {
  position: fixed;
  bottom: 32px; right: 50px;
  width: 40px; height: 40px;
  background: var(--blue);
  border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  z-index: 890;
  box-shadow: 0 4px 16px rgba(0,0,0,0.3);
  transition: background 0.2s, transform 0.2s;
}
.back-to-top:hover { background: var(--blue-mid); transform: translateY(-2px); }

/* ─── CARDS & COMMON ─── */
.card { background: var(--card-bg); border: 1px solid var(--border); }
.off-card { background: var(--off); border: 1px solid var(--border); }
.info-row { display: flex; gap: 12px; padding: 9px 0; border-bottom: 1px dashed var(--border); font-size: 13px; }
.info-label { color: var(--muted); min-width: 120px; flex-shrink: 0; }
.info-value { color: var(--text); font-weight: 500; }
.page-wrap { padding: 36px 32px; max-width: 1100px; margin: 0 auto; }
.page-wrap-sm { padding: 36px 32px; max-width: 900px; margin: 0 auto; }

/* ─── SCROLL ANIMATION OBSERVER ─── */
.observe-me { opacity: 0; }
.observe-me.is-visible { opacity: 1; }

/* ══════════════════════════════════════════
   RESPONSIVE — TABLET (768px+)
══════════════════════════════════════════ */
@media (max-width: 1023px) {
  .header-badges { display: none; }
  .search-input { width: 180px; }
  .dept-grid { grid-template-columns: repeat(2, 1fr); }
  .footer-grid { grid-template-columns: 1fr 1fr; gap: 24px; }
  .stats-strip { grid-template-columns: repeat(3, 1fr); }
  .home-main { grid-template-columns: 1fr; }
  .home-sidebar { border-top: 1px solid var(--border); }
}

/* ══════════════════════════════════════════
   RESPONSIVE — MOBILE (< 768px)
══════════════════════════════════════════ */
@media (max-width: 767px) {
  /* Utilbar */
  .utilbar { padding: 6px 16px; }
  .utilbar-left { display: none; }
  .utilbar-link { display: none; }
  .utilbar-divider { display: none; }

  /* Header */
  .site-header { padding: 12px 16px; gap: 12px; flex-wrap: wrap; }
  .header-logo { width: 52px; height: 52px; }
  .header-divider { display: none; }
  .header-name { font-size: 15px; }
  .header-sub { display: none; }
  .header-right { margin-left: 0; width: 100%; align-items: stretch; }
  .header-badges { display: none; }
  .search-form { width: 100%; }
  .search-input { width: 100%; flex: 1; }

  /* Nav */
  .nav-desktop { display: none; }
  .nav-ext-links { display: none; }
  .hamburger { display: flex; }
  .main-nav { justify-content: space-between; }
  .nav-mobile-brand { display: flex !important; }

  /* Hero */
  .hero { height: auto; min-height: 260px; }
  .hero-content { width: 100%; padding: 28px 20px; }
  .hero-title { font-size: 20px; }
  .hero-desc { font-size: 12px; max-width: 100%; }
  .hero-dots { left: 20px; }

  /* Stats */
  .stats-strip { grid-template-columns: repeat(2, 1fr); }
  .stat-item:nth-child(2) { border-right: none; }

  /* Home */
  .home-main { grid-template-columns: 1fr; }
  .home-content { padding: 20px 16px; border-right: none; border-bottom: 1px solid var(--border); }

  /* Departments */
  .dept-grid { grid-template-columns: repeat(2, 1fr); }

  /* Testimonial */
  .testimonial-section { padding: 28px 16px; }
  .testimonial-card { padding: 24px 20px; }
  .testimonial-text { font-size: 13px; }

  /* Recruiters */
  .recruiters-header { padding: 0 16px 20px; }

  /* Footer */
  .footer-grid { grid-template-columns: 1fr; gap: 24px; padding: 28px 16px; }
  .footer-bottom { padding: 12px 16px; flex-direction: column; align-items: flex-start; gap: 6px; }

  /* Page wraps */
  .page-wrap { padding: 20px 16px; }
  .page-wrap-sm { padding: 20px 16px; }
  .page-banner { padding: 20px 16px; }
  .page-banner h1 { font-size: 18px; }

  /* Social sidebar */
  .social-sidebar { display: none; }
  .back-to-top { right: 16px; bottom: 20px; }

  /* Section heading */
  .section-heading h2 { font-size: 13px; }
}

/* footer map mobile overrides moved to main mobile block */

/* ─── FOOTER MAP SPLIT ─── */
.footer-map-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  min-height: 260px;
}
.footer-map-embed {
  width: 100%;
  min-height: 260px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.08);
  filter: grayscale(30%) brightness(0.85);
  transition: filter 0.3s;
}
.footer-weather {
  min-height: 260px;
}

/* ─── BROCHURE SECTION ─── */
.brochure-section { padding: 0 32px 32px; }
.brochure-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
}
.brochure-card {
  background: var(--white);
  border: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  gap: 0;
  text-decoration: none;
  transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
  overflow: hidden;
}
.brochure-card:hover {
  box-shadow: 0 6px 24px rgba(26,58,107,0.12);
  transform: translateY(-2px);
  border-color: var(--blue);
}
.brochure-icon-wrap {
  width: 100%;
  padding: 20px 0 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.brochure-body {
  padding: 12px 14px 8px;
  flex: 1;
}
.brochure-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 3px;
}
.brochure-sub {
  font-size: 11px;
  color: var(--muted);
  line-height: 1.4;
  margin-bottom: 4px;
}
.brochure-size {
  font-size: 10px;
  color: var(--light-text);
  font-weight: 500;
}
.brochure-dl {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 14px;
  font-size: 11px;
  font-weight: 600;
  border-top: 1px solid var(--border);
  background: var(--off);
  letter-spacing: 0.3px;
  text-transform: uppercase;
}

/* ─── GALLERY SHOWCASE ─── */
.gallery-showcase {
  padding: 32px;
  background: var(--off);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}
.gallery-view-all {
  font-size: 12px;
  font-weight: 600;
  color: var(--blue-mid);
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
}
.gallery-filters {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-bottom: 16px;
}
.gallery-filter-btn {
  background: var(--white);
  border: 1px solid var(--border);
  color: var(--muted);
  font-size: 11px;
  font-weight: 600;
  padding: 5px 14px;
  cursor: pointer;
  letter-spacing: 0.3px;
  text-transform: uppercase;
  transition: background 0.15s, color 0.15s, border-color 0.15s;
}
.gallery-filter-btn:hover { background: var(--blue-light); color: var(--blue); border-color: var(--blue); }
.gallery-filter-btn.active { background: var(--blue); color: white; border-color: var(--blue); }

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: 160px;
  gap: 6px;
}
.gallery-tile {
  position: relative;
  overflow: hidden;
  background: var(--blue-light);
  border: 1px solid var(--border);
}
.gallery-tile-tall { grid-row: span 2; }
.gallery-tile img { transition: transform 0.4s ease; }
.gallery-tile:hover img { transform: scale(1.05); }
.gallery-tile-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(10,20,50,0.85) 0%, transparent 50%);
  opacity: 0;
  transition: opacity 0.25s;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 12px;
}
.gallery-tile:hover .gallery-tile-overlay { opacity: 1; }
.gallery-tile-title { font-size: 12px; font-weight: 600; color: white; line-height: 1.3; }
.gallery-tile-cat { font-size: 10px; color: rgba(255,255,255,0.6); margin-top: 2px; text-transform: uppercase; letter-spacing: 0.5px; }

/* Lightbox */
.gallery-lightbox {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.92);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.2s ease;
}
.gallery-lightbox-close {
  position: absolute;
  top: 20px; right: 20px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  color: white;
  width: 36px; height: 36px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  font-size: 16px;
  border-radius: 2px;
}
.gallery-lightbox-inner {
  max-width: 90vw;
  box-shadow: 0 20px 80px rgba(0,0,0,0.8);
  overflow: hidden;
}

/* ─── MOBILE HEADER ODIA ─── */
@media (max-width: 767px) {
  .header-odia { font-size: 11px; }
  .header-sub { display: none; }
  /* Search goes below logo row */
  .site-header { flex-wrap: wrap; }
  .header-right { order: 3; width: 100%; align-items: stretch; margin-left: 0; }
  .header-badges { display: none; }
  .search-form { width: 100%; }
  .search-input { flex: 1; width: 100%; }

  /* Footer map split stacks on mobile */
  .footer-map-split { grid-template-columns: 1fr; height: auto; }
  .footer-map-embed { height: 200px; }
  .footer-weather { height: 260px; }

  /* Brochure grid */
  .brochure-section { padding: 0 16px 24px; }
  .brochure-grid { grid-template-columns: 1fr 1fr; }

  /* Gallery */
  .gallery-showcase { padding: 20px 16px; }
  .gallery-grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 130px; }
}

@media (max-width: 1023px) {
  .brochure-grid { grid-template-columns: repeat(2, 1fr); }
  .gallery-grid { grid-template-columns: repeat(3, 1fr); }
  .footer-map-split { height: 200px; }
}

/* ─── MOBILE NAV BRAND ─── */
.nav-mobile-brand {
  display: none;
  align-items: center;
  gap: 8px;
  padding: 0 14px;
}
.nav-mobile-brand img {
  width: 28px; height: 28px;
  object-fit: contain;
  filter: brightness(0) invert(1);
  opacity: 0.9;
}
.nav-mobile-brand-text {
  font-family: 'Source Serif 4, serif';
  font-size: 12px;
  color: white;
  line-height: 1.2;
}
.nav-mobile-brand-odia {
  font-size: 9px;
  color: rgba(255,255,255,0.5);
}

/* ─── SECTION HEADING REFINEMENT ─── */
.section-heading h2 {
  font-family: 'Source Serif 4, serif';
  font-size: 15px !important;
  font-weight: 600;
  color: var(--blue) !important;
  background: transparent !important;
  padding: 0 16px 0 0 !important;
  position: relative;
  white-space: nowrap;
  border-left: 3px solid var(--blue);
  padding-left: 12px !important;
}

/* ─── STATS STRIP ENHANCEMENT ─── */
.stat-num {
  font-family: 'Source Serif 4, serif';
  font-size: 26px !important;
  font-weight: 600;
  color: var(--blue);
  line-height: 1;
}
.stat-item {
  padding: 20px 20px !important;
  border-right: 1px solid var(--border);
  text-align: center;
  position: relative;
  transition: background 0.2s;
}
.stat-item:hover { background: var(--blue-light); }
.stat-item::after {
  content: '';
  display: block;
  width: 24px; height: 2px;
  background: var(--red);
  margin: 6px auto 0;
  opacity: 0;
  transition: opacity 0.2s;
}
.stat-item:hover::after { opacity: 1; }
