# =============================================
# GCEKJR Website — Environment Variables
# Copy this file to .env.local and fill values
# =============================================

# --- NextAuth ---
NEXTAUTH_SECRET=your-random-secret-here   # generate with: openssl rand -base64 32
NEXTAUTH_URL=https://gcekjr.ac.in         # IMPORTANT: must be your production URL, not localhost

# --- Admin Credentials ---
ADMIN_EMAIL=admin@gcekjr.ac.in
ADMIN_PASSWORD=admin@123

# --- Google Sheets API ---
# 1. Go to console.cloud.google.com
# 2. Create project → Enable "Google Sheets API" & "Google Drive API"
# 3. Create Service Account → Download JSON key
# 4. Share your Google Sheet with the service account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=gcekjr-site@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# --- Google Spreadsheet ID ---
# The ID from your sheet URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here

# NOTE: GET /api/* routes are intentionally public (they serve the public-facing website).
# Only POST/DELETE routes are protected by NextAuth session checks.
