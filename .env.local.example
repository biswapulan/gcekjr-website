# =============================================
# GCEKJR Website — Environment Variables
# Copy this file to .env.local and fill values
# =============================================

# --- NextAuth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=your-random-secret-here

# IMPORTANT: For local dev use http://localhost:3000
# For production use your actual domain: https://gcekjr.ac.in
NEXTAUTH_URL=http://localhost:3000

# --- Admin Credentials ---
ADMIN_EMAIL=admin@gcekjr.ac.in
ADMIN_PASSWORD=your-secure-password-here

# --- Google Sheets API ---
# 1. Go to console.cloud.google.com
# 2. Create project → Enable "Google Sheets API" & "Google Drive API"
# 3. Create Service Account → Download JSON key
# 4. Share your Google Sheet with the service account email (Editor role)
GOOGLE_SERVICE_ACCOUNT_EMAIL=gcekjr-site@your-project.iam.gserviceaccount.com

# Paste the full private key including -----BEGIN/END----- lines.
# The \n must be literal backslash-n (not a newline) because .env files are single-line.
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBAAK...\n-----END RSA PRIVATE KEY-----"

# --- Google Spreadsheet ID ---
# Get from your sheet URL: docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here
